import{_ as e,o as l,c as r,a2 as n}from"./chunks/framework.DnrXFDHb.js";const y=JSON.parse('{"title":"附錄 C：題項專屬審計約束矩陣","description":"","frontmatter":{},"headers":[],"relativePath":"附錄C_題項專屬審計約束矩陣.md","filePath":"附錄C_題項專屬審計約束矩陣.md"}'),d={name:"附錄C_題項專屬審計約束矩陣.md"};function a(s,t,g,o,i,f){return l(),r("div",null,[...t[0]||(t[0]=[n('<h1 id="附錄-c-題項專屬審計約束矩陣" tabindex="-1">附錄 C：題項專屬審計約束矩陣 <a class="header-anchor" href="#附錄-c-題項專屬審計約束矩陣" aria-label="Permalink to &quot;附錄 C：題項專屬審計約束矩陣&quot;">​</a></h1><blockquote><p>本附錄為 03_審計專家協議 3.6 節的參考資料。各題項的關鍵數據與校準路徑如下：</p></blockquote><h3 id="財務組-f01-f18" tabindex="-1">財務組 (F01-F18) <a class="header-anchor" href="#財務組-f01-f18" aria-label="Permalink to &quot;財務組 (F01-F18)&quot;">​</a></h3><table tabindex="0"><thead><tr><th style="text-align:left;">題號</th><th style="text-align:left;">關鍵數據與校準路徑</th></tr></thead><tbody><tr><td style="text-align:left;"><strong>F01-F03</strong></td><td style="text-align:left;">強制進行 3 年財務對比；F03 須計算「訂單能見天數」：<code>CurrentContractLiabilities / AvgRevenuePerDay</code>。</td></tr><tr><td style="text-align:left;"><strong>F04</strong></td><td style="text-align:left;">[業外純度穿透]：檢測處分資產是否掩蓋本業虧損；核對子公司認列方法。</td></tr><tr><td style="text-align:left;"><strong>F05-F07</strong></td><td style="text-align:left;">[存貨與應收專項] 計算「營運週期 (CCC)」；F07 執行「階差分析」。</td></tr><tr><td style="text-align:left;"><strong>F08</strong></td><td style="text-align:left;">用「在建工程/預付設備款」驗證資本支出進度。</td></tr><tr><td style="text-align:left;"><strong>F09-F10</strong></td><td style="text-align:left;">檢索「固定成本/折舊/薪資」佔比，執行「經營槓桿拐點」分析。</td></tr><tr><td style="text-align:left;"><strong>F11</strong></td><td style="text-align:left;">辨識資產處分是「戰略轉型」還是「祖產求生」。</td></tr><tr><td style="text-align:left;"><strong>F12</strong></td><td style="text-align:left;">計算各年度「研發產出比 (Revenue/R&amp;D)」。</td></tr><tr><td style="text-align:left;"><strong>F13</strong></td><td style="text-align:left;">[股利覆蓋率]：分析配息是否來自「借貸」或「處分收益」。</td></tr><tr><td style="text-align:left;"><strong>F14</strong></td><td style="text-align:left;">分析負債結構與利息保障倍數趨勢。</td></tr><tr><td style="text-align:left;"><strong>F15</strong></td><td style="text-align:left;">檢索「內部人/大股東持股異動」，偵測誠信風險。</td></tr><tr><td style="text-align:left;"><strong>F16-F17</strong></td><td style="text-align:left;">調用「股權分散表」；分析「增資成本價格帶」與「週變動鎖碼特徵」。</td></tr><tr><td style="text-align:left;"><strong>F18</strong></td><td style="text-align:left;">綜合評估，給出最終買賣建議。</td></tr></tbody></table><h3 id="經營組-g01-g11" tabindex="-1">經營組 (G01-G11) <a class="header-anchor" href="#經營組-g01-g11" aria-label="Permalink to &quot;經營組 (G01-G11)&quot;">​</a></h3><table tabindex="0"><thead><tr><th style="text-align:left;">題號</th><th style="text-align:left;">關鍵數據與校準路徑</th></tr></thead><tbody><tr><td style="text-align:left;"><strong>G01</strong></td><td style="text-align:left;">資料時間一致性校準，確保歷史沿革與現狀對齊。</td></tr><tr><td style="text-align:left;"><strong>G02</strong></td><td style="text-align:left;">深度分析「法人代表更換」背景。</td></tr><tr><td style="text-align:left;"><strong>G03</strong></td><td style="text-align:left;">獲取核心人員離職率資訊。</td></tr><tr><td style="text-align:left;"><strong>G04-G06</strong></td><td style="text-align:left;">[產品與通路校準]：比對三年內「主要客戶佔比」變動；G04 含市佔率校準。</td></tr><tr><td style="text-align:left;"><strong>G07</strong></td><td style="text-align:left;">[研發實質性]：核對「研發費用」與「研發成果」之變現率。</td></tr><tr><td style="text-align:left;"><strong>G08</strong></td><td style="text-align:left;">[市場與風險敞口]：檢索「分部資訊」獲取區域營收。</td></tr><tr><td style="text-align:left;"><strong>G09</strong></td><td style="text-align:left;">[供應鏈安全性]：導出「前十大客戶/供應商」清單，計算「集中度風險指數」；含合作夥伴戰略深度。</td></tr><tr><td style="text-align:left;"><strong>G10</strong></td><td style="text-align:left;">[護城河]：分析產業壁壘與競爭優勢持久性。</td></tr><tr><td style="text-align:left;"><strong>G11</strong></td><td style="text-align:left;">[戰略執行力預測]：核對「購置固定資產」支出，驗證擴產宣稱；含新業務展望。</td></tr></tbody></table>',6)])])}const _=e(d,[["render",a]]);export{y as __pageData,_ as default};
